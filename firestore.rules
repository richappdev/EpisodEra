rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isNullableString(value) {
      return value == null || value is string;
    }

    function isNullablePositiveInt(value) {
      return value == null || (value is int && value > 0);
    }

    function validMediaType(value) {
      return value in ['movie', 'tv'];
    }

    function validWatchlistStatus(value) {
      return value in ['planned', 'watching', 'completed', 'dropped', 'unwatched', 'watched'];
    }

    function validLanguage(value) {
      return value in ['en-US', 'zh-TW'];
    }

    function validUserProfile() {
      return request.resource.data.keys().hasOnly([
          'firstName', 'lastName', 'email', 'displayName', 'photoURL', 'bio', 'country', 'timezone', 'friendCode', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['firstName', 'lastName', 'email'])
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() > 0
        && isNullableString(request.resource.data.email)
        && (!('displayName' in request.resource.data) || isNullableString(request.resource.data.displayName))
        && (!('photoURL' in request.resource.data) || isNullableString(request.resource.data.photoURL))
        && (!('bio' in request.resource.data) || isNullableString(request.resource.data.bio))
        && (!('country' in request.resource.data) || isNullableString(request.resource.data.country))
        && (!('timezone' in request.resource.data) || isNullableString(request.resource.data.timezone))
        && (!('friendCode' in request.resource.data) || isNullableString(request.resource.data.friendCode));
    }

    function validWatchlistItem(itemId) {
      return itemId.matches('^(movie|tv)_[1-9][0-9]*$')
        && request.resource.data.keys().hasOnly([
          'tmdbId', 'mediaType', 'title', 'poster', 'backdrop', 'status', 'addedAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['tmdbId', 'mediaType', 'title', 'status'])
        && request.resource.data.tmdbId is int
        && request.resource.data.tmdbId > 0
        && validMediaType(request.resource.data.mediaType)
        && request.resource.data.title is string
        && validWatchlistStatus(request.resource.data.status)
        && (!('poster' in request.resource.data) || isNullableString(request.resource.data.poster))
        && (!('backdrop' in request.resource.data) || isNullableString(request.resource.data.backdrop));
    }

    function validNextEpisode(value) {
      return value == null || (
        value is map
        && value.keys().hasOnly(['episodeKey', 'seasonNumber', 'episodeNumber', 'episodeTitle'])
        && value.keys().hasAll(['episodeKey', 'seasonNumber', 'episodeNumber', 'episodeTitle'])
        && value.episodeKey is string
        && value.episodeKey.matches('^s[0-9]{2,}e[0-9]{2,}$')
        && value.seasonNumber is int
        && value.seasonNumber > 0
        && value.episodeNumber is int
        && value.episodeNumber > 0
        && value.episodeTitle is string
      );
    }

    function validProgress(showId) {
      return showId.matches('^[1-9][0-9]*$')
        && request.resource.data.keys().hasOnly([
          'tmdbId', 'title', 'totalEpisodes', 'watchedEpisodeCount', 'progressPercent',
          'currentSeason', 'currentEpisode', 'nextEpisode', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'tmdbId', 'title', 'totalEpisodes', 'watchedEpisodeCount', 'progressPercent',
          'currentSeason', 'currentEpisode'
        ])
        && request.resource.data.tmdbId is int
        && request.resource.data.tmdbId > 0
        && request.resource.data.title is string
        && request.resource.data.totalEpisodes is int
        && request.resource.data.totalEpisodes >= 0
        && request.resource.data.watchedEpisodeCount is int
        && request.resource.data.watchedEpisodeCount >= 0
        && request.resource.data.watchedEpisodeCount <= request.resource.data.totalEpisodes
        && request.resource.data.progressPercent is number
        && request.resource.data.progressPercent >= 0
        && request.resource.data.progressPercent <= 100
        && isNullablePositiveInt(request.resource.data.currentSeason)
        && isNullablePositiveInt(request.resource.data.currentEpisode)
        && (!('nextEpisode' in request.resource.data) || validNextEpisode(request.resource.data.nextEpisode));
    }

    function validEpisode(episodeKey) {
      return episodeKey.matches('^s[0-9]{2,}e[0-9]{2,}$')
        && request.resource.data.keys().hasOnly([
          'seasonNumber', 'episodeNumber', 'episodeTitle', 'watched', 'watchedAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['seasonNumber', 'episodeNumber', 'episodeTitle', 'watched'])
        && request.resource.data.seasonNumber is int
        && request.resource.data.seasonNumber > 0
        && request.resource.data.episodeNumber is int
        && request.resource.data.episodeNumber > 0
        && request.resource.data.episodeTitle is string
        && request.resource.data.watched == true;
    }

    function validHistory(historyId) {
      return historyId.matches('^(movie_[1-9][0-9]*|tv_[1-9][0-9]*_s[0-9]{2,}e[0-9]{2,})$')
        && request.resource.data.keys().hasOnly([
          'tmdbId', 'mediaType', 'title', 'seasonNumber', 'episodeNumber', 'episodeTitle', 'watchedAt', 'updatedAt', 'rewatchCount', 'genreNames', 'runtimeMinutes'
        ])
        && request.resource.data.keys().hasAll([
          'tmdbId', 'mediaType', 'title', 'seasonNumber', 'episodeNumber', 'episodeTitle'
        ])
        && request.resource.data.tmdbId is int
        && request.resource.data.tmdbId > 0
        && validMediaType(request.resource.data.mediaType)
        && request.resource.data.title is string
        && isNullablePositiveInt(request.resource.data.seasonNumber)
        && isNullablePositiveInt(request.resource.data.episodeNumber)
        && isNullableString(request.resource.data.episodeTitle)
        && (!('rewatchCount' in request.resource.data) || (request.resource.data.rewatchCount is int && request.resource.data.rewatchCount >= 0))
        && (!('genreNames' in request.resource.data) || (request.resource.data.genreNames is list && request.resource.data.genreNames.size() <= 32))
        && (!('runtimeMinutes' in request.resource.data) || request.resource.data.runtimeMinutes == null || (request.resource.data.runtimeMinutes is int && request.resource.data.runtimeMinutes > 0));
    }

    function validSettings(settingsId) {
      return settingsId == 'profile'
        && request.resource.data.keys().hasOnly([
          'autoMarkPreviousEpisodesWatched',
          'language',
          'preferredProviderIds',
          'watchRegion',
          'achievementsEnabled',
          'showAchievementsOnProfile',
          'shareActivityWithFriends',
          'allowFriendRequests',
          'hideSpoilersUntilWatched',
          'updatedAt',
        ])
        && request.resource.data.keys().hasAll(['autoMarkPreviousEpisodesWatched', 'language'])
        && request.resource.data.autoMarkPreviousEpisodesWatched is bool
        && validLanguage(request.resource.data.language)
        && (
          !('preferredProviderIds' in request.resource.data)
          || (
            request.resource.data.preferredProviderIds is list
            && request.resource.data.preferredProviderIds.size() <= 12
          )
        )
        && (
          !('watchRegion' in request.resource.data)
          || (
            request.resource.data.watchRegion is string
            && request.resource.data.watchRegion.matches('^[A-Za-z]{2}$')
          )
        )
        && (!('achievementsEnabled' in request.resource.data) || request.resource.data.achievementsEnabled is bool)
        && (!('showAchievementsOnProfile' in request.resource.data) || request.resource.data.showAchievementsOnProfile is bool)
        && (!('shareActivityWithFriends' in request.resource.data) || request.resource.data.shareActivityWithFriends is bool)
        && (!('allowFriendRequests' in request.resource.data) || request.resource.data.allowFriendRequests is bool)
        && (!('hideSpoilersUntilWatched' in request.resource.data) || request.resource.data.hideSpoilersUntilWatched is bool);
    }

    function validRating(itemId) {
      return itemId.matches('^(movie|tv)_[1-9][0-9]*$')
        && request.resource.data.keys().hasOnly([
          'tmdbId', 'mediaType', 'rating', 'review', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll(['tmdbId', 'mediaType', 'rating'])
        && request.resource.data.tmdbId is int
        && request.resource.data.tmdbId > 0
        && validMediaType(request.resource.data.mediaType)
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && (!('review' in request.resource.data) || isNullableString(request.resource.data.review));
    }

    match /users/{userId} {
      allow create, update: if isOwner(userId) && validUserProfile();
      allow read, delete: if isOwner(userId);

      match /watchlist/{itemId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validWatchlistItem(itemId);
      }

      match /ratings/{itemId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validRating(itemId);
      }

      match /progress/{showId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validProgress(showId);

        match /episodes/{episodeKey} {
          allow read, delete: if isOwner(userId);
          allow create, update: if isOwner(userId) && validEpisode(episodeKey);
        }
      }

      match /history/{historyId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validHistory(historyId);
      }

      match /settings/{settingsId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && validSettings(settingsId);
      }

      match /friends/{friendId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if false;
      }
    }

    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
