<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".EpisoderaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EpisodEra">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.EpisodEra">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="episodera" android:host="movie" android:pathPrefix="/" />
                <data android:scheme="episodera" android:host="tv" android:pathPrefix="/" />
                <data android:scheme="episodera" android:host="play" android:pathPrefix="/" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="episodera.web.app" android:pathPrefix="/movie" />
                <data android:scheme="https" android:host="episodera.web.app" android:pathPrefix="/tv" />
                <data android:scheme="https" android:host="episodera.web.app" android:pathPrefix="/play" />
            </intent-filter>
        </activity>
    </application>

</manifest>
