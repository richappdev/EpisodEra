CORS_ORIGINS=https://episodera.web.app,https://episodera.firebaseapp.com
PUBLIC_READ_RATE_LIMIT_MAX=120
PUBLIC_READ_RATE_LIMIT_WINDOW_MS=60000
AUTH_WRITE_RATE_LIMIT_MAX=60
AUTH_WRITE_RATE_LIMIT_WINDOW_MS=60000

# App Check Phase 2 is always on (monitor). Phase 3 enforcement (default off):
# APP_CHECK_ENFORCE_AUTH_WRITES=true
# Phase 4 public-read enforcement (not mounted until ready):
# APP_CHECK_ENFORCE_PUBLIC_READS=true

# Production smoke (Auth REST) cannot mint App Check JWTs. When enforcement is on,
# enable a secret-gated bypass for CI only:
# SMOKE_BYPASS_APP_CHECK=true
# SMOKE_BYPASS_APP_CHECK_SECRET=replace-with-long-random-secret

# Comma-separated emails allowed to use /admin/puzzles APIs:
# PUZZLE_ADMIN_EMAILS=you@example.com

# Supabase Phase 4–6 shadow dual-write (Firestore remains primary + read source):
# SUPABASE_URL=https://xyhhnoxvydshqpypwccr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SHADOW_WRITES=true
# Optional profile reads from Supabase (default off):
# SUPABASE_READ_PROFILES=true
# Settings + watchlist/likes reads (default off):
# SUPABASE_READ_SETTINGS=true
# SUPABASE_READ_WATCHLIST=true
# Phase 10 prep (do not enable until soak):
# FIRESTORE_WRITES_DISABLED=true
# SUPABASE_READ_PRIMARY=true
