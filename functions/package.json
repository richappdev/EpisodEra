{
  "name": "episodera-functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run build && node --test \"lib/**/*.test.js\"",
    "test:emulator": "npm run build && firebase emulators:exec --only firestore \"node --test 'lib/**/*.emulator.test.js'\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.1.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.1",
    "eslint": "^9.8.0",
    "firebase": "^12.16.0",
    "firebase-tools": "^15.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0"
  }
}
