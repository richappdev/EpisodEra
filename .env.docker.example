# Copy to .env (repo root) for Docker Compose local testing.
# Browser-facing URLs must use 127.0.0.1 / localhost — the browser runs on the host.

TMDB_API_KEY=replace-with-local-tmdb-api-key
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099
VITE_API_BASE_URL=http://127.0.0.1:5001/episodera/us-central1/api
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=episodera.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=episodera
VITE_FIREBASE_APP_ID=replace-with-firebase-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=replace-with-firebase-measurement-id
